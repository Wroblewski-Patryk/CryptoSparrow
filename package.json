{
  "name": "CryptoSparrow",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "backend/dev": "node scripts/dev-backend.mjs",
    "server/dev": "pnpm run backend/dev",
    "backend:dev": "pnpm run backend/dev",
    "frontend/dev": "node scripts/dev-frontend.mjs",
    "client/dev": "pnpm run frontend/dev",
    "frontend:dev": "pnpm run frontend/dev",
    "workers/dev": "node scripts/dev-workers.mjs",
    "workers:dev": "pnpm run workers/dev",
    "lint": "pnpm -r --if-present run lint",
    "typecheck": "pnpm -r --if-present run typecheck",
    "test": "pnpm -r --if-present run test",
    "build": "pnpm -r --if-present run build",
    "go-live:infra:up": "docker compose up -d postgres redis",
    "go-live:infra:down": "docker compose down",
    "test:go-live:server": "pnpm --filter server test -- src/modules/auth/auth.e2e.test.ts src/modules/strategies/strategies.e2e.test.ts src/modules/backtests/backtests.e2e.test.ts src/modules/engine/preTrade.e2e.test.ts",
    "test:go-live:server:with-infra": "node scripts/goLiveSmoke.mjs --target=server",
    "test:go-live:client": "pnpm --filter client exec vitest run src/features/bots/components/BotsManagement.test.tsx src/features/logs/components/AuditTrailView.test.tsx src/ui/layout/dashboard/Header.responsive.test.tsx",
    "test:go-live:smoke": "node scripts/goLiveSmoke.mjs --target=full"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.13.1",
  "devDependencies": {
    "@types/node": "^24.1.0",
    "eslint": "^9.31.0",
    "prettier": "^3.6.2",
    "typescript": "^5.8.3"
  }
}
