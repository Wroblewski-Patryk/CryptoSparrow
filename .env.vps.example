# CryptoSparrow VPS fallback env template (docker-compose.vps.yml)

NODE_ENV=production

# Public URLs (adjust to your domain/reverse proxy)
SERVER_URL=http://localhost:3001
CLIENT_URL=http://localhost:3002
CORS_ORIGINS=http://localhost:3002
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001

# API auth / encryption (replace before production use)
JWT_SECRET=replace-with-strong-secret
# Optional shared cookie domain for web + api subdomains
# Example: .soar.luckysparrow.ch
# COOKIE_DOMAIN=
API_KEY_ENCRYPTION_KEYS=v1:replace-with-32-byte-secret
API_KEY_ENCRYPTION_ACTIVE_VERSION=v1

# Data stores
# If using compose --profile infra, defaults below are valid.
# If using managed DB/Redis, replace with external URLs.
DATABASE_URL=postgresql://postgres:password@postgres:5432/cryptosparrow?schema=public
REDIS_URL=redis://redis:6379

# Optional tuning
SERVER_PORT=3001
