// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


model User {
  id        String   @id @default(cuid())

  email     String   @unique
  password  String
  name      String?
  avatarUrl String?
  role      Role     @default(USER)

  apiKeys   ApiKey[]
  strategies Strategy[]
  marketUniverses MarketUniverse[]
  symbolGroups SymbolGroup[]
  bots      Bot[]
  positions Position[]
  orders    Order[]
  trades    Trade[]
  signals   Signal[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  USER
  ADMIN
}

model ApiKey {
  id         String   @id @default(uuid())
  userId     String

  label      String
  exchange   Exchange @default(BINANCE)
  apiKey     String
  apiSecret  String

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  lastUsed   DateTime?
  user       User     @relation(fields: [userId], references: [id])
}

enum Exchange {
  BINANCE
}



model Strategy {
  id           String   @id @default(uuid())
  userId       String

  name         String  
  description  String?  
  interval     String  
  leverage     Int  
  walletRisk   Float 
  config       Json 

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id])
  botStrategies BotStrategy[]
  positions     Position[]
  orders        Order[]
  trades        Trade[]
  signals       Signal[]
}

model MarketUniverse {
  id                String   @id @default(uuid())
  userId            String

  name              String
  baseCurrency      String   @default("USDT")
  filterRules       Json?
  whitelist         String[] @default([])
  blacklist         String[] @default([])
  autoExcludeRules  Json?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user              User     @relation(fields: [userId], references: [id])
  symbolGroups      SymbolGroup[]

  @@index([userId])
}

model SymbolGroup {
  id                String         @id @default(uuid())
  userId            String
  marketUniverseId  String

  name              String
  symbols           String[]       @default([])

  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  user              User           @relation(fields: [userId], references: [id])
  marketUniverse    MarketUniverse @relation(fields: [marketUniverseId], references: [id])
  botStrategies     BotStrategy[]

  @@index([userId])
  @@index([marketUniverseId])
}

model Bot {
  id                String          @id @default(uuid())
  userId            String

  name              String
  mode              BotMode         @default(PAPER)
  isActive          Boolean         @default(false)
  liveOptIn         Boolean         @default(false)
  maxOpenPositions  Int             @default(1)

  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  user              User            @relation(fields: [userId], references: [id])
  botStrategies     BotStrategy[]
  positions         Position[]
  orders            Order[]
  trades            Trade[]
  signals           Signal[]

  @@index([userId])
}

model BotStrategy {
  id                String      @id @default(uuid())
  botId             String
  strategyId        String
  symbolGroupId     String

  isEnabled         Boolean     @default(true)

  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  bot               Bot         @relation(fields: [botId], references: [id])
  strategy          Strategy    @relation(fields: [strategyId], references: [id])
  symbolGroup       SymbolGroup @relation(fields: [symbolGroupId], references: [id])

  @@unique([botId, strategyId, symbolGroupId])
  @@index([botId])
  @@index([strategyId])
  @@index([symbolGroupId])
}

enum BotMode {
  PAPER
  LIVE
  LOCAL
}

model Position {
  id                String         @id @default(uuid())
  userId            String
  botId             String?
  strategyId        String?

  symbol            String
  side              PositionSide
  status            PositionStatus @default(OPEN)
  entryPrice        Float
  quantity          Float
  leverage          Int            @default(1)
  stopLoss          Float?
  takeProfit        Float?
  openedAt          DateTime       @default(now())
  closedAt          DateTime?
  realizedPnl       Float?
  unrealizedPnl     Float?

  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  user              User           @relation(fields: [userId], references: [id])
  bot               Bot?           @relation(fields: [botId], references: [id])
  strategy          Strategy?      @relation(fields: [strategyId], references: [id])
  orders            Order[]
  trades            Trade[]

  @@index([userId])
  @@index([botId])
  @@index([strategyId])
  @@index([symbol])
  @@index([status])
}

model Order {
  id                String      @id @default(uuid())
  userId            String
  botId             String?
  strategyId        String?
  positionId        String?

  symbol            String
  side              OrderSide
  type              OrderType
  status            OrderStatus  @default(PENDING)
  quantity          Float
  price             Float?
  stopPrice         Float?
  filledQuantity    Float        @default(0)
  averageFillPrice  Float?
  fee               Float?
  exchangeOrderId   String?
  submittedAt       DateTime?
  filledAt          DateTime?
  canceledAt        DateTime?

  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  user              User        @relation(fields: [userId], references: [id])
  bot               Bot?        @relation(fields: [botId], references: [id])
  strategy          Strategy?   @relation(fields: [strategyId], references: [id])
  position          Position?   @relation(fields: [positionId], references: [id])
  trades            Trade[]

  @@index([userId])
  @@index([botId])
  @@index([strategyId])
  @@index([positionId])
  @@index([symbol])
  @@index([status])
}

model Trade {
  id                String      @id @default(uuid())
  userId            String
  botId             String?
  strategyId        String?
  orderId           String?
  positionId        String?

  symbol            String
  side              OrderSide
  price             Float
  quantity          Float
  fee               Float?
  realizedPnl       Float?
  executedAt        DateTime    @default(now())

  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  user              User        @relation(fields: [userId], references: [id])
  bot               Bot?        @relation(fields: [botId], references: [id])
  strategy          Strategy?   @relation(fields: [strategyId], references: [id])
  order             Order?      @relation(fields: [orderId], references: [id])
  position          Position?   @relation(fields: [positionId], references: [id])

  @@index([userId])
  @@index([botId])
  @@index([strategyId])
  @@index([orderId])
  @@index([positionId])
  @@index([symbol])
}

model Signal {
  id                String          @id @default(uuid())
  userId            String
  botId             String?
  strategyId        String?

  symbol            String
  timeframe         String
  direction         SignalDirection
  confidence        Float?
  payload           Json?
  triggeredAt       DateTime        @default(now())

  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  user              User            @relation(fields: [userId], references: [id])
  bot               Bot?            @relation(fields: [botId], references: [id])
  strategy          Strategy?       @relation(fields: [strategyId], references: [id])

  @@index([userId])
  @@index([botId])
  @@index([strategyId])
  @@index([symbol])
  @@index([triggeredAt])
}

enum PositionSide {
  LONG
  SHORT
}

enum PositionStatus {
  OPEN
  CLOSED
  LIQUIDATED
}

enum OrderSide {
  BUY
  SELL
}

enum OrderType {
  MARKET
  LIMIT
  STOP
  STOP_LIMIT
  TAKE_PROFIT
  TRAILING
}

enum OrderStatus {
  PENDING
  OPEN
  PARTIALLY_FILLED
  FILLED
  CANCELED
  REJECTED
  EXPIRED
}

enum SignalDirection {
  LONG
  SHORT
  EXIT
}
