# CryptoSparrow API environment template
# Copy to: apps/api/.env

# Core runtime
NODE_ENV=development
SERVER_PORT=3001
CLIENT_PORT=3002
SERVER_URL=http://localhost:3001
CLIENT_URL=http://localhost:3002
CORS_ORIGINS=http://localhost:3002

# Data stores
DATABASE_URL=postgresql://postgres:password@localhost:5432/cryptosparrow?schema=public
REDIS_URL=redis://localhost:6379

# Auth / crypto
JWT_SECRET=replace-with-strong-secret
# Optional shared cookie domain for web + api subdomains
# Example: COOKIE_DOMAIN=.soar.luckysparrow.ch
# COOKIE_DOMAIN=
# Optional JWT rotation window
# JWT_SECRET_PREVIOUS=previous-secret
# JWT_SECRET_PREVIOUS_UNTIL=2026-12-31T23:59:59.000Z

# API key encryption (versioned keyring)
# Format: version:key,version:key
API_KEY_ENCRYPTION_KEYS=v1:replace-with-32-byte-secret
API_KEY_ENCRYPTION_ACTIVE_VERSION=v1

# Optional compatibility alias
# API_KEY_ENCRYPTION=<legacy-single-key>

# Subscription payments (provider-agnostic abstraction)
SUBSCRIPTION_PAYMENT_PROVIDER=MANUAL
# Stripe adapter (used when SUBSCRIPTION_PAYMENT_PROVIDER=STRIPE)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PRICE_ID_ADVANCED_MONTHLY=price_...
# STRIPE_PRICE_ID_PROFESSIONAL_MONTHLY=price_...

# Binance and market stream
BINANCE_SPOT_REST_URL=https://api.binance.com
BINANCE_FUTURES_REST_URL=https://fapi.binance.com
BINANCE_STREAM_URL=wss://stream.binance.com:9443/stream
MARKET_STREAM_MARKET_TYPE=FUTURES
MARKET_STREAM_INTERVALS=5m
MARKET_STREAM_SYMBOLS=BTCUSDT,ETHUSDT,BNBUSDT
MARKET_STREAM_SUBSCRIPTIONS_REFRESH_MS=10000

# Coin icon resolver (CoinGecko + fallback)
COINGECKO_API_BASE_URL=https://api.coingecko.com/api/v3
# Optional in local/dev, recommended for stage/prod
# COINGECKO_API_KEY=
COIN_ICON_CACHE_TTL_MINUTES=360

# Runtime defaults
RUNTIME_SCAN_INTERVAL_MS=5000
RUNTIME_SCAN_MAX_SYMBOLS=100
RUNTIME_REFERENCE_BALANCE_USDT=10000
RUNTIME_SIGNAL_QUANTITY=0.01
RUNTIME_SIGNAL_MIN_DIRECTIONAL_SCORE=1
RUNTIME_SIGNAL_DEDUPE_RETENTION_MS=600000
RUNTIME_SIGNAL_WARMUP_ENABLED=true
RUNTIME_SIGNAL_WARMUP_CANDLES=120
RUNTIME_SIGNAL_WARMUP_RETRY_MS=5000
RUNTIME_SCAN_WATCHDOG_ENABLED=true
RUNTIME_SESSION_WATCHDOG_INTERVAL_MS=60000
RUNTIME_SIGNAL_LOOP_BOOTSTRAP_INTERVAL_MS=10000

# Paper/live fee and trailing defaults
RUNTIME_TAKER_FEE_RATE=0.001
RUNTIME_LIVE_TAKER_FEE_RATE=0.001
RUNTIME_TRAILING_ENABLED=true
RUNTIME_TRAILING_TYPE=PERCENT
RUNTIME_TRAILING_VALUE=1

# DCA defaults
RUNTIME_DCA_ENABLED=true
RUNTIME_DCA_STEP_PERCENT=2
RUNTIME_DCA_MAX_ADDS=2
RUNTIME_DCA_ADD_SIZE_FRACTION=1

# Worker telemetry keys (optional)
# WORKER_MODE=runtime
# WORKER_EXECUTION_QUEUE=execution
# WORKER_MARKET_DATA_QUEUE=market-data
# WORKER_BACKTEST_QUEUE=backtest

# Ops endpoint guardrails (optional)
# OPS_ALLOW_PRIVATE_NETWORK=true
# OPS_ALLOWED_IPS=127.0.0.1,::1
# Proxy trust chain hardening (recommended in stage/prod)
# TRUSTED_PROXY_IPS=10.0.0.10,10.0.0.11
# TRUST_PROXY_ALLOW_PRIVATE=false
