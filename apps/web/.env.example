# CryptoSparrow Web environment template
# Copy to: apps/web/.env.local

NODE_ENV=development

# Public API endpoint used by browser/runtime calls
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001

# Optional: show backend egress IP hint in Binance API key form (comma-separated)
# Example: NEXT_PUBLIC_BINANCE_IP_WHITELIST=203.0.113.10,203.0.113.11
NEXT_PUBLIC_BINANCE_IP_WHITELIST=

# Used by auth middleware/session checks
JWT_SECRET=replace-with-strong-secret
